# ============================================================
# 复制为 .env 后填写真实值：cp .env.example .env
# 带 * 的字段必须修改，不可使用示例值
# ============================================================

# ── PostgreSQL 主数据库 ──────────────────────────────────────
POSTGRES_USER=kb_user
POSTGRES_PASSWORD=change_me_db_password*
POSTGRES_DB=enterprise_kb

# 本地直连（docker compose 外直接运行 backend 时使用）
DATABASE_URL=postgresql+asyncpg://kb_user:change_me_db_password*@localhost:5432/enterprise_kb

# ── Langfuse 数据库密码 ──────────────────────────────────────
LANGFUSE_DB_PASSWORD=change_me_langfuse_db_password*

# ── Langfuse 服务配置 ────────────────────────────────────────
# NEXTAUTH_SECRET 和 SALT 需要是随机字符串，可用以下命令生成：
#   python -c "import secrets; print(secrets.token_hex(32))"
LANGFUSE_NEXTAUTH_SECRET=change_me_random_32chars*
LANGFUSE_SALT=change_me_random_salt*

# 首次启动后，访问 http://localhost:3000 注册账号，
# 创建项目并生成 API Key，填入下方：
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# docker compose 内自动覆盖为 http://langfuse:3000，无需修改
LANGFUSE_HOST=http://localhost:3000

# ── DeepSeek API ─────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx*
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── JWT 鉴权 ─────────────────────────────────────────────────
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_jwt_secret_at_least_32_chars*
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── 嵌入与重排模型 ───────────────────────────────────────────
# 首次运行自动从 HuggingFace 下载（bge-m3 约 2.3GB，reranker 约 568MB）
# 设置 HF_ENDPOINT 可使用镜像：https://hf-mirror.com
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
EMBEDDING_DEVICE=cpu   # cpu | cuda | mps

# ── 检索超参数 ───────────────────────────────────────────────
RETRIEVAL_TOP_K=20     # 向量+全文各取前 N，合并后送 reranker
RERANK_TOP_K=5         # reranker 精排后保留 N 个 chunk 送 LLM
RRF_K=60               # RRF 融合公式中的平滑常数（原论文默认值）

# ── 生成层 ───────────────────────────────────────────────────
# reranker 最高分低于此值 → 跳过 LLM，直接返回"知识库中未找到相关内容"
# bge-reranker-v2-m3 normalize=True 分布：<0.1≈无关，0.1~0.3≈弱相关，>0.3≈相关
RERANK_THRESHOLD=0.15
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
